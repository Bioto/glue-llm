# GlueLLM Configuration
# Copy this file to .env and configure your settings

# Default model to use (format: "provider:model_name")
GLUELLM_DEFAULT_MODEL=openai:gpt-5.4-nano

# Default system prompt for all completions
GLUELLM_DEFAULT_SYSTEM_PROMPT=You are a helpful assistant.

# Default max completion tokens per LLM call (optional; overridable per client and per call; e.g. 8192 for Anthropic)
# GLUELLM_DEFAULT_MAX_TOKENS=8192

# Reasoning effort for o3/o4-mini/Claude thinking models: none|minimal|low|medium|high|xhigh|auto
# GLUELLM_DEFAULT_REASONING_EFFORT=auto

# Allow parallel tool calls when multiple tools are requested
# GLUELLM_DEFAULT_PARALLEL_TOOL_CALLS=true

# Maximum number of tool execution iterations (prevents infinite loops)
GLUELLM_MAX_TOOL_ITERATIONS=10

# Model used for dynamic tool routing (tool_mode=dynamic)
# GLUELLM_TOOL_ROUTE_MODEL=openai:gpt-5.4-nano

# Retry configuration
GLUELLM_RETRY_MAX_ATTEMPTS=3
GLUELLM_RETRY_MIN_WAIT=2
GLUELLM_RETRY_MAX_WAIT=30
GLUELLM_RETRY_MULTIPLIER=1

# Request timeout configuration (in seconds)
GLUELLM_DEFAULT_REQUEST_TIMEOUT=300.0
GLUELLM_MAX_REQUEST_TIMEOUT=1800.0

# Logging Configuration
# Completely disable GlueLLM's logging setup (use your application's logging config)
# GLUELLM_DISABLE_LOGGING=false
# Console log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
GLUELLM_LOG_LEVEL=INFO
# File log level (typically DEBUG for full details)
GLUELLM_LOG_FILE_LEVEL=DEBUG
# Log directory (default: logs/)
# GLUELLM_LOG_DIR=logs
# Log file name
# GLUELLM_LOG_FILE_NAME=gluellm.log
# Enable JSON structured logging for log aggregation tools (ELK, Datadog, etc.)
# GLUELLM_LOG_JSON_FORMAT=false
# Enable console output (default: false for library usage, set to true for standalone apps)
# GLUELLM_LOG_CONSOLE_OUTPUT=false
# Maximum log file size before rotation (in bytes, default: 10MB)
# GLUELLM_LOG_MAX_BYTES=10485760
# Number of backup log files to keep
# GLUELLM_LOG_BACKUP_COUNT=5

# Optional: API keys (can also be set via provider-specific env vars)
# GLUELLM_OPENAI_API_KEY=your-openai-api-key
# GLUELLM_ANTHROPIC_API_KEY=your-anthropic-api-key
# GLUELLM_XAI_API_KEY=your-xai-api-key

# Provider-specific API keys (recognized by any-llm-sdk)
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
# XAI_API_KEY=your-xai-api-key

# OpenTelemetry Tracing Configuration
# Enable distributed tracing with MLflow for observability
# GLUELLM_ENABLE_TRACING=false
# GLUELLM_MLFLOW_TRACKING_URI=http://localhost:5000
# GLUELLM_MLFLOW_EXPERIMENT_NAME=gluellm
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5000/v1/traces

# Context summarization (message-count threshold; optional AAAK lossless shorthand)
# GLUELLM_DEFAULT_SUMMARIZE_CONTEXT=false
# GLUELLM_DEFAULT_SUMMARIZE_CONTEXT_THRESHOLD=20
# GLUELLM_DEFAULT_SUMMARIZE_CONTEXT_KEEP_RECENT=6
# GLUELLM_AAAK_COMPRESSION_ENABLED=false
# GLUELLM_AAAK_COMPRESSION_MODEL=openai:gpt-4o-mini
# GLUELLM_AAAK_TOOL_CONDENSING=false
